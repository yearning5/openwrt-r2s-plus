# Target platform
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y

# Build BOTH R2S and R2S Plus
# R2S must be included so its u-boot gets compiled — R2S Plus reuses it
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r2s=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopi-r2s-plus=y

# Filesystem
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_EXT4_BLOCKSIZE_4K=y
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# eMMC kernel support
CONFIG_PACKAGE_kmod-mmc=y

# OAF packages (compiled from source — kernel magic matches exactly)
CONFIG_PACKAGE_oaf=y
CONFIG_PACKAGE_kmod-oaf=y
CONFIG_PACKAGE_luci-app-oaf=y

# OAF kernel dependencies
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y

# LuCI web interface
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-firewall=y

# AdGuard Home for DNS history per device
CONFIG_PACKAGE_adguardhome=y

# Network
CONFIG_PACKAGE_kmod-r8152=y

# Useful tools
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_openssh-sftp-server=y
